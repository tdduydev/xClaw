# ============================================================
# AutoX - AI Agent Platform
# ============================================================

# LLM Provider (openai | anthropic | ollama)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# API Keys
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434/v1

# LLM Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Server
PORT=3001
NODE_ENV=development

# Agent
AGENT_NAME=AutoX
AGENT_PERSONA=A helpful AI assistant that can assist with programming, healthcare, and many other tasks.
