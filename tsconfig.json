{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2022"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "composite": true,
        "paths": {
            "@autox/core": [
                "./packages/core/src"
            ],
            "@autox/shared": [
                "./packages/shared/src"
            ],
            "@autox/skills": [
                "./packages/skills/src"
            ],
            "@autox/server": [
                "./packages/server/src"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}